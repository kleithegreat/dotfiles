+bool CWindow::shouldSquareTopCorners() {
+    if (!m_isFloating || rounding() <= 0)
+        return false;
+
+    const auto SELF = m_self.lock();
+    if (!SELF)
+        return false;
+
+    const auto INCLUDED = g_pDecorationPositioner->getBoxWithIncludedDecos(SELF);
+    const auto TOPDECO  = getWindowMainSurfaceBox().y - INCLUDED.y;
+
+    return TOPDECO > getRealBorderSize() + 0.5;
