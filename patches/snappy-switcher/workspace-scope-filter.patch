diff --git a/src/hyprland.c b/src/hyprland.c
index d1f9319..d6c2e2c 100644
--- a/src/hyprland.c
+++ b/src/hyprland.c
@@ -237,6 +237,43 @@ static int parse_clients(const char *json_str, AppState *state) {
   return 0;
 }
 
+/* --- Active Workspace Query --- */
+static int get_active_workspace_id(void) {
+  char *json_str = hyprland_request("j/activeworkspace");
+  if (!json_str)
+    return -1;
+
+  struct json_object *root = json_tokener_parse(json_str);
+  free(json_str);
+  if (!root)
+    return -1;
+
+  struct json_object *id_obj;
+  if (!json_object_object_get_ex(root, "id", &id_obj)) {
+    json_object_put(root);
+    return -1;
+  }
+
+  int id = json_object_get_int(id_obj);
+  json_object_put(root);
+  return id;
+}
+
+/* --- Workspace Scope Filtering --- */
+static void filter_by_workspace(AppState *state, int workspace_id) {
+  int dst = 0;
+  for (int src = 0; src < state->count; src++) {
+    if (state->windows[src].workspace_id == workspace_id) {
+      if (dst != src)
+        state->windows[dst] = state->windows[src];
+      dst++;
+    } else {
+      window_info_free(&state->windows[src]);
+    }
+  }
+  state->count = dst;
+}
+
 /* --- Aggregation (Context Mode) --- */
 static void aggregate_context(AppState *state) {
   if (state->count <= 1)
@@ -311,6 +348,13 @@ int update_window_list(AppState *state, Config *cfg) {
   }
   free(json);
 
+  /* Filter to active workspace if configured */
+  if (cfg && cfg->scope == SCOPE_WORKSPACE) {
+    int active_ws = get_active_workspace_id();
+    if (active_ws >= 0)
+      filter_by_workspace(state, active_ws);
+  }
+
   if (state->count > 1) {
     qsort(state->windows, state->count, sizeof(WindowInfo), compare_mru);
   }
