#!/usr/bin/env python3
"""Sunrise/sunset scheduler for hyprsunset and dark_hint.

Manages night light (hyprsunset) and GTK dark preference based on solar times.
Uses GeoClue2 for location when available, falls back to hardcoded coordinates.

Usage:
    sun-schedule schedule        Compute times, apply state, set systemd timers
    sun-schedule sunset-action   Start hyprsunset (called at sunset)
    sun-schedule sunrise-action  Stop hyprsunset, set dark_hint false (at sunrise)
    sun-schedule dark-on         Set dark_hint true (called at 11 PM)
"""

from __future__ import annotations

import json
import math
import os
import subprocess
import sys
from datetime import datetime, date, time, timedelta, timezone
from pathlib import Path

# ── Configuration ─────────────────────────────────────────────────────
REPO_DIR = Path(__file__).parent.parent
APPLY_THEME = REPO_DIR / "themes" / "apply-theme"

# Fallback location: College Station, TX
DEFAULT_LAT = 30.6280
DEFAULT_LON = -96.3344

HYPRSUNSET_TEMP = 4500
DARK_ON_HOUR = 23  # 11 PM local time

TIMER_NAMES = ["sun-event-sunset", "sun-event-sunrise", "sun-event-dark-on"]


# ── Location ──────────────────────────────────────────────────────────

def get_location() -> tuple[float, float]:
    """Get latitude/longitude from GeoClue2 cache or hardcoded fallback."""
    cache = Path(
        os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"),
        "sun-schedule", "location.json",
    )

    # Try cached location
    try:
        data = json.loads(cache.read_text())
        return data["latitude"], data["longitude"]
    except (FileNotFoundError, json.JSONDecodeError, KeyError, ValueError):
        pass

    # Try GeoClue2 via where-am-i
    try:
        result = subprocess.run(
            ["timeout", "10", "where-am-i"],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode == 0:
            lat = lon = None
            for line in result.stdout.splitlines():
                low = line.lower()
                if "latitude" in low:
                    lat = float(line.split(":")[-1].strip().rstrip("\u00b0"))
                elif "longitude" in low:
                    lon = float(line.split(":")[-1].strip().rstrip("\u00b0"))
            if lat is not None and lon is not None:
                cache.parent.mkdir(parents=True, exist_ok=True)
                cache.write_text(json.dumps({"latitude": lat, "longitude": lon}))
                return lat, lon
    except (FileNotFoundError, subprocess.TimeoutExpired, ValueError, OSError):
        pass

    return DEFAULT_LAT, DEFAULT_LON


# ── Solar calculation (NOAA algorithm) ────────────────────────────────

def sun_times(lat: float, lon: float, dt: date) -> tuple[datetime, datetime]:
    """Calculate sunrise and sunset for a given date and location.

    Uses the NOAA solar calculator algorithm (US Naval Observatory variant).
    Returns (sunrise, sunset) as timezone-aware local datetime objects.
    """
    day_of_year = dt.timetuple().tm_yday
    lng_hour = lon / 15.0

    def _compute(rising: bool) -> float:
        t = day_of_year + ((6 if rising else 18) - lng_hour) / 24
        # Sun's mean anomaly
        M = 0.9856 * t - 3.289
        # Sun's true longitude
        L = (M + 1.916 * math.sin(math.radians(M))
             + 0.020 * math.sin(math.radians(2 * M)) + 282.634) % 360
        # Right ascension (adjusted to same quadrant as L)
        RA = math.degrees(math.atan(0.91764 * math.tan(math.radians(L))))
        RA += (L // 90) * 90 - (RA // 90) * 90
        RA /= 15  # convert to hours
        # Declination
        sin_dec = 0.39782 * math.sin(math.radians(L))
        cos_dec = math.cos(math.asin(sin_dec))
        # Hour angle
        cos_H = (math.cos(math.radians(90.833))
                 - sin_dec * math.sin(math.radians(lat))) / \
                (cos_dec * math.cos(math.radians(lat)))
        cos_H = max(-1.0, min(1.0, cos_H))
        H_deg = math.degrees(math.acos(cos_H))
        H = (360 - H_deg) / 15 if rising else H_deg / 15
        # Local mean time -> UTC
        T = H + RA - 0.06571 * t - 6.622
        return (T - lng_hour) % 24

    base = datetime(dt.year, dt.month, dt.day, tzinfo=timezone.utc)
    sunrise = (base + timedelta(hours=_compute(True))).astimezone()
    sunset = (base + timedelta(hours=_compute(False))).astimezone()
    # Handle UTC day-boundary wrap (sunset UTC can be past midnight for
    # western longitudes, making the naive conversion land on the wrong day).
    if sunset < sunrise:
        sunset += timedelta(days=1)
    return sunrise, sunset


# ── Actions ───────────────────────────────────────────────────────────

def start_hyprsunset() -> None:
    """Start hyprsunset via Hyprland if not already running."""
    if subprocess.run(["pgrep", "-x", "hyprsunset"],
                      capture_output=True).returncode == 0:
        return
    subprocess.run(
        ["hyprctl", "dispatch", "exec",
         f"hyprsunset -t {HYPRSUNSET_TEMP}"],
        capture_output=True,
    )


def stop_hyprsunset() -> None:
    """Stop hyprsunset if running."""
    subprocess.run(["pkill", "-x", "hyprsunset"], capture_output=True)


def set_dark_hint(enabled: bool) -> None:
    """Toggle dark_hint via apply-theme."""
    subprocess.run(
        [sys.executable, str(APPLY_THEME),
         "set", "dark_hint", str(enabled).lower()],
        capture_output=True,
    )


# ── Transient timer management ────────────────────────────────────────

def cancel_timers() -> None:
    """Cancel existing sun-event transient timers."""
    for name in TIMER_NAMES:
        subprocess.run(["systemctl", "--user", "stop", f"{name}.timer"],
                       capture_output=True)


def create_timer(name: str, when: datetime, args: list[str]) -> None:
    """Create a transient systemd user timer for a specific time."""
    subprocess.run(
        ["systemd-run", "--user", "--collect",
         f"--on-calendar={when.strftime('%Y-%m-%d %H:%M:%S')}",
         f"--unit={name}",
         "--timer-property=Persistent=true",
         "--"] + args,
        capture_output=True,
    )


# ── Commands ──────────────────────────────────────────────────────────

def cmd_schedule() -> None:
    """Main scheduler: compute times, apply current state, create timers."""
    lat, lon = get_location()
    now = datetime.now().astimezone()
    today = now.date()
    tomorrow = today + timedelta(days=1)

    sunrise, sunset = sun_times(lat, lon, today)
    sunrise_next, sunset_next = sun_times(lat, lon, tomorrow)

    # Next occurrence of each event
    next_sunrise = sunrise if sunrise > now else sunrise_next
    next_sunset = sunset if sunset > now else sunset_next
    dark_on_today = now.replace(hour=DARK_ON_HOUR, minute=0,
                                second=0, microsecond=0)
    next_dark_on = (dark_on_today if dark_on_today > now
                    else dark_on_today + timedelta(days=1))

    # Determine and apply current state
    is_night = now < sunrise or now >= sunset
    is_dark = now >= dark_on_today or now < sunrise

    if is_night:
        start_hyprsunset()
    else:
        stop_hyprsunset()
    set_dark_hint(is_dark)

    print(f"Location: {lat:.4f}, {lon:.4f}")
    print(f"Sunrise:  {sunrise.strftime('%H:%M')}  "
          f"Sunset: {sunset.strftime('%H:%M')}")
    print(f"State:    night={is_night}  dark_hint={is_dark}")
    print(f"Next:     sunrise={next_sunrise.strftime('%m-%d %H:%M')}  "
          f"sunset={next_sunset.strftime('%m-%d %H:%M')}  "
          f"dark_on={next_dark_on.strftime('%m-%d %H:%M')}")

    # Create transient timers for upcoming events
    cancel_timers()
    script = str(Path(__file__).resolve())
    py = sys.executable
    create_timer("sun-event-sunrise", next_sunrise,
                 [py, script, "sunrise-action"])
    create_timer("sun-event-sunset", next_sunset,
                 [py, script, "sunset-action"])
    create_timer("sun-event-dark-on", next_dark_on,
                 [py, script, "dark-on"])


def cmd_sunrise_action() -> None:
    """Sunrise: stop night light and clear dark hint."""
    stop_hyprsunset()
    set_dark_hint(False)


def cmd_sunset_action() -> None:
    """Sunset: start night light."""
    start_hyprsunset()


def cmd_dark_on() -> None:
    """11 PM: enable dark hint."""
    set_dark_hint(True)


# ── Entry point ───────────────────────────────────────────────────────

COMMANDS = {
    "schedule": cmd_schedule,
    "sunset-action": cmd_sunset_action,
    "sunrise-action": cmd_sunrise_action,
    "dark-on": cmd_dark_on,
}

if __name__ == "__main__":
    if len(sys.argv) != 2 or sys.argv[1] not in COMMANDS:
        print(f"Usage: {sys.argv[0]} {{{','.join(COMMANDS)}}}",
              file=sys.stderr)
        sys.exit(1)
    COMMANDS[sys.argv[1]]()
