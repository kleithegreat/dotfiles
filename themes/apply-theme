#!/usr/bin/env python3
"""Hot-swap theming CLI for Hyprland/NixOS desktop."""

from __future__ import annotations

import argparse
import json
import sys
import typing
from dataclasses import asdict, fields
from pathlib import Path

# Allow running from anywhere — add the repo root to sys.path.
THEMES_DIR = Path(__file__).resolve().parent
REPO_DIR = THEMES_DIR.parent
if str(REPO_DIR) not in sys.path:
    sys.path.insert(0, str(REPO_DIR))

from themes.lib.resolve import load_colors, load_state, save_state
from themes.lib.schema import ThemeState
from themes.lib.orchestrator import (
    apply_all,
    apply_target,
    apply_targets,
    targets_for_key,
)

COLORS_DIR = THEMES_DIR / "colors"
PRESETS_DIR = THEMES_DIR / "presets"
STATE_PATH = THEMES_DIR / "state.json"

# ── Subcommand groups ────────────────────────────────────────────────────

# "colors" subcommand: every color-dependent target except wallpaper/cursor.
# Wallpaper is added dynamically when palette filtering is enabled.
_BASE_COLOR_TARGETS = {
    "alacritty", "ghostty", "hyprland", "zathura", "quickshell",
    "neovim", "starship", "tmux", "gtk", "qt", "vicinae", "bat",
    "snappy_switcher",
}

# "fonts" subcommand: targets that depend on any font-related key
_FONT_TARGETS = {
    "alacritty", "ghostty", "quickshell", "tmux", "gtk", "qt", "vicinae",
    "snappy_switcher",
}


def _load(args: argparse.Namespace) -> tuple:
    """Load state + colors, exiting on error."""
    try:
        state = load_state(STATE_PATH)
    except (FileNotFoundError, ValueError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        sys.exit(1)
    try:
        colors = load_colors(state.color_scheme, COLORS_DIR)
    except (FileNotFoundError, ValueError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        sys.exit(1)
    return state, colors


def _color_targets_for_state(state: ThemeState) -> set[str]:
    """Return targets affected by the current color scheme."""
    targets = set(_BASE_COLOR_TARGETS)
    if state.filter_wallpaper:
        targets.add("wallpaper")
    return targets


def cmd_all(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying all targets ({colors.family}-{colors.variant})...")
    if not apply_all(colors, state):
        sys.exit(1)


def cmd_colors(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying color targets ({colors.family}-{colors.variant})...")
    if not apply_targets(_color_targets_for_state(state), colors, state):
        sys.exit(1)


def cmd_wallpaper(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying wallpaper ({state.wallpaper})...")
    if not apply_targets({"wallpaper"}, colors, state):
        sys.exit(1)


def cmd_cursor(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying cursor ({state.cursor_theme} {state.cursor_size})...")
    if not apply_targets({"cursor"}, colors, state):
        sys.exit(1)


def cmd_fonts(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying font targets ({state.mono_font}, {state.system_font})...")
    if not apply_targets(_FONT_TARGETS, colors, state):
        sys.exit(1)


def cmd_sync(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Syncing theme-managed config ({colors.family}-{colors.variant})...")
    if not apply_all(colors, state, runtime=False, sync_safe=True):
        sys.exit(1)


def cmd_target(args: argparse.Namespace) -> None:
    state, colors = _load(args)
    print(f"Applying target: {args.name}...")
    if not apply_target(args.name, colors, state):
        sys.exit(1)


def cmd_set(args: argparse.Namespace) -> None:
    key, value = args.key, args.value
    valid_keys = {f.name for f in fields(ThemeState)}
    if key not in valid_keys:
        print(f"error: unknown key '{key}'. Valid: {', '.join(sorted(valid_keys))}", file=sys.stderr)
        sys.exit(1)

    state = load_state(STATE_PATH)
    state_dict = asdict(state)

    # Coerce int fields
    int_fields = {name for name, tp in typing.get_type_hints(ThemeState).items() if tp is int}
    if key in int_fields:
        try:
            value = int(value)
        except ValueError:
            print(f"error: '{key}' must be an integer, got '{value}'", file=sys.stderr)
            sys.exit(1)

    # Coerce bool fields
    bool_fields = {name for name, tp in typing.get_type_hints(ThemeState).items() if tp is bool}
    if key in bool_fields:
        truthy = {"true", "on", "dark", "yes", "1"}
        falsy = {"false", "off", "light", "no", "0"}
        if value.lower() in truthy:
            value = True
        elif value.lower() in falsy:
            value = False
        else:
            print(f"error: '{key}' must be a boolean (true/false, on/off, dark/light), got '{value}'", file=sys.stderr)
            sys.exit(1)

    if state_dict[key] == value:
        print(f"{key} is already '{value}', nothing to do.")
        return

    state_dict[key] = value
    new_state = ThemeState(**state_dict)
    save_state(new_state, STATE_PATH)
    print(f"Set {key} = {value!r}")

    colors = load_colors(new_state.color_scheme, COLORS_DIR)
    affected = targets_for_key(key, new_state)
    if affected:
        print(f"Applying affected targets...")
        if not apply_targets(affected, colors, new_state):
            sys.exit(1)


def cmd_preset(args: argparse.Namespace) -> None:
    path = PRESETS_DIR / f"{args.name}.json"
    if not path.is_file():
        available = sorted(p.stem for p in PRESETS_DIR.glob("*.json"))
        print(
            f"error: preset '{args.name}' not found. "
            f"Available: {', '.join(available) or '(none)'}",
            file=sys.stderr,
        )
        sys.exit(1)

    preset = json.loads(path.read_text())
    state = load_state(STATE_PATH)
    state_dict = asdict(state)
    state_dict.update(preset)
    new_state = ThemeState(**state_dict)
    save_state(new_state, STATE_PATH)
    print(f"Loaded preset '{args.name}', applying all targets...")
    colors = load_colors(new_state.color_scheme, COLORS_DIR)
    if not apply_all(colors, new_state):
        sys.exit(1)


def cmd_list_schemes(args: argparse.Namespace) -> None:
    schemes = sorted(p.stem for p in COLORS_DIR.glob("*.json"))
    if not schemes:
        print("No color schemes found.")
        return
    for s in schemes:
        print(f"  {s}")


def cmd_list_presets(args: argparse.Namespace) -> None:
    presets = sorted(p.stem for p in PRESETS_DIR.glob("*.json"))
    if not presets:
        print("No presets found.")
        return
    for p in presets:
        print(f"  {p}")


def cmd_status(args: argparse.Namespace) -> None:
    try:
        state = load_state(STATE_PATH)
    except (FileNotFoundError, ValueError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        sys.exit(1)
    for f in fields(ThemeState):
        print(f"  {f.name}: {getattr(state, f.name)}")


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="apply-theme",
        description="Hot-swap theming for Hyprland/NixOS desktop.",
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("all", help="Apply all targets")
    sub.add_parser("colors", help="Apply color-dependent targets")
    sub.add_parser("wallpaper", help="Apply wallpaper only")
    sub.add_parser("cursor", help="Apply cursor only")
    sub.add_parser("fonts", help="Apply font-dependent targets")
    sub.add_parser("sync", help="Write theme-managed config without live-session reloads")

    p_target = sub.add_parser("target", help="Apply a single target")
    p_target.add_argument("name")

    p_set = sub.add_parser("set", help="Update state and apply affected targets")
    p_set.add_argument("key")
    p_set.add_argument("value")

    p_preset = sub.add_parser("preset", help="Load a preset and apply all")
    p_preset.add_argument("name")

    sub.add_parser("list-schemes", help="List available color schemes")
    sub.add_parser("list-presets", help="List available presets")
    sub.add_parser("status", help="Show current theme state")

    args = parser.parse_args()
    dispatch = {
        "all": cmd_all,
        "colors": cmd_colors,
        "wallpaper": cmd_wallpaper,
        "cursor": cmd_cursor,
        "fonts": cmd_fonts,
        "sync": cmd_sync,
        "target": cmd_target,
        "set": cmd_set,
        "preset": cmd_preset,
        "list-schemes": cmd_list_schemes,
        "list-presets": cmd_list_presets,
        "status": cmd_status,
    }

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    dispatch[args.command](args)


if __name__ == "__main__":
    main()
