{
    "workbench.iconTheme": "gruvbox-material-icon-theme",
    "files.autoSave": "afterDelay",
    "gitlens.gitCommands.skipConfirmations": [
        "fetch:command",
        "stash-push:command",
        "switch:command",
        "push:command"
    ],
    "markdownlint.config": {
        "MD024": false
    },
    "tabnine.experimentalAutoImports": true,
    "workbench.startupEditor": "none",
    "catppuccin.accentColor": "blue",
    "editor.accessibilitySupport": "off",
    "editor.codeLensFontFamily": "JetBrainsMonoNL NF",
    "editor.inlayHints.fontFamily": "JetBrainsMonoNL NF",
    "[python]": {
        "editor.formatOnType": true
    },
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "always",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "telemetry.telemetryLevel": "off",
    "editor.inlineSuggest.enabled": true,
    "editor.largeFileOptimizations": false,
    "settingsSync.ignoredSettings": [
        "editor.fontSize",
        "editor.fontFamily",
        "editor.codeLensFontFamily",
        "editor.inlayHints.fontFamily",
        "terminal.integrated.fontFamily"
    ],
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false,
        "haskell": false
    },
    "settingsSync.ignoredExtensions": [
        "mathematic.vscode-pdf"
    ],
    "editor.fontLigatures": true,
    "editor.multiCursorModifier": "ctrlCmd",
    "svelte.enable-ts-plugin": true,
    "liveServer.settings.donotShowInfoMsg": true,
    "remote.SSH.remotePlatform": {
        "linux.cse.tamu.edu": "linux",
        "10.0.0.245": "linux",
        "192.168.8.153": "linux"
    },
    "github.copilot.editor.enableAutoCompletions": true,
    "csv-preview.capitalizeHeaders": false,
    "terminal.integrated.inheritEnv": false,
    "window.customTitleBarVisibility": "auto",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "makefile.configureOnOpen": true,
    "editor.experimentalInlineEdit.fontFamily": "JetBrainsMono NF",
    "editor.minimap.autohide": "mouseover",
    "editor.inlineSuggest.suppressSuggestions": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "css.customData": [
        ".vscode/tailwind.json"
    ],
    "[cpp]": {
        "editor.wordBasedSuggestions": "off",
        "editor.semanticHighlighting.enabled": true,
        "editor.stickyScroll.defaultModel": "foldingProviderModel",
        "editor.suggest.insertMode": "replace"
    },
    "remote.defaultExtensionsIfInstalledLocally": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github"
    ],
    "workbench.editor.empty.hint": "hidden",
    "docker.extension.enableComposeLanguageServer": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "Cargo.toml": "Cargo.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "haskell.manageHLS": "PATH",
    "[haskell]": {},
    "docker.extension.dockerEngineAvailabilityPrompt": false,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "*.qrc": "qt-core.qrcEditor",
        "*.pdf": "pdf.view"
    },
    "qt-qml.doNotAskForQmllsDownload": true
}
