{
  "$schema": "https://vicinae.com/schemas/config.json",
  "providers": {
    "applications": {
      "preferences": {
        // Vicinae documents relative-path support for top-level imports only.
        // Provider search paths remain literal strings here for now.
        "paths": [
          "/home/kevin/.local/share/applications",
          "/home/kevin/.nix-profile/share/applications",
          "/run/current-system/sw/share/applications",
          "/etc/profiles/per-user/kevin/share/applications"
        ]
      }
    }
  }
}
